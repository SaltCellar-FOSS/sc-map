# Set default behavior to automatically normalize line endings
* text=auto

# Shell scripts should always use LF line endings
*.sh text eol=lf
*.bash text eol=lf

# Docker files should use LF
Dockerfile* text eol=lf
docker-compose* text eol=lf
*.dockerfile text eol=lf

# Node.js files
*.js text eol=lf
*.ts text eol=lf
*.json text eol=lf

# Other common text files
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf